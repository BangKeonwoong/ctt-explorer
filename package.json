{
  "name": "ctt-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data:fetch": "python3 scripts/fetch_ctt.py",
    "data:build": "python3 scripts/build_dataset.py",
    "build": "npm run data:build && vite build --outDir docs && touch docs/.nojekyll",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "python3 -m unittest discover -s tests -p 'test_*.py' && ./node_modules/.bin/tsx --test src/lib/urlState.test.ts src/lib/ctt.test.ts src/lib/loaders.test.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
